generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String        @id @default(uuid())
  name        String
  email       String        @unique
  phone       String?
  company     String?
  jobTitle    String?
  companySize CompanySize?
  industry    Industry?
  source      LeadSource    @default(MANUAL)
  status      LeadStatus    @default(NEW)

  emailOpens    Int @default(0)
  websiteVisits Int @default(0)
  formFills     Int @default(0)

  ruleScore     Int?
  mlScore       Float?
  activeScore   Int           @default(0)
  scoreCategory ScoreCategory @default(COLD)

  actuallyConverted Boolean?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interactions       Interaction[]
  scoringHistory     ScoringHistory[]
  scoringComparisons ScoringComparison[]
  customer           Customer?

  @@index([status, scoreCategory])
  @@index([createdAt])
  @@index([ruleScore, mlScore])
}

model ScoringRule {
  id          String   @id @default(uuid())
  ruleName    String   @unique
  category    String
  points      Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScoringHistory {
  id          String      @id @default(uuid())
  leadId      String
  oldScore    Int
  newScore    Int
  scoringMode ScoringMode
  reason      String
  triggeredBy String
  latencyMs   Int?
  createdAt   DateTime    @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
}

model ScoringComparison {
  id            String        @id @default(uuid())
  leadId        String
  ruleScore     Int
  mlScore       Float
  delta         Float
  ruleCategory  ScoreCategory
  mlCategory    ScoreCategory
  agreement     Boolean
  ruleLatencyMs Int
  mlLatencyMs   Int
  createdAt     DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
}

model Interaction {
  id        String          @id @default(uuid())
  leadId    String
  type      InteractionType
  notes     String?
  timestamp DateTime        @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
}

model Customer {
  id             String   @id @default(uuid())
  leadId         String   @unique
  conversionDate DateTime @default(now())
  lifetimeValue  Float?

  lead Lead @relation(fields: [leadId], references: [id])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  FORM
  WEBHOOK
  MANUAL
  IMPORT
}

enum CompanySize {
  STARTUP
  SME
  ENTERPRISE
}

enum ScoreCategory {
  COLD
  WARM
  HOT
}

enum ScoringMode {
  RULES
  ML
}

enum InteractionType {
  EMAIL
  CALL
  MEETING
  DEMO
}

enum Industry {
  TECH
  FINANCE
  HEALTHCARE
  RETAIL
  MANUFACTURING
  OTHER
}